# Optional. Defaults are optimized for deployable AICRM PPT generation.
CODEX_SKILL_NAME=gpt-image2-ppt
CODEX_SKILL_DIR=./vendor/gpt-image2-ppt-skills
GPT_IMAGE_BACKEND=openai
GPT_IMAGE_CONCURRENCY=1
GPT_IMAGE_ENDPOINT=images
GPT_IMAGE_MODEL_NAME=gpt-image-2
GPT_IMAGE_SIZE=1792x1024
GPT_IMAGE_QUALITY=high

# Use the same image2-compatible provider as AICRM.
IMAGE2_API_KEY=
IMAGE2_BASE_URL=https://www.tokenrouter.tech/v1

# Public URL of this PPT service after deployment.
PPT_PUBLIC_BASE_URL=
