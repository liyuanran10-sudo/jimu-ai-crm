{
  "manifest_version": 3,
  "name": "GPT to Notion Capture",
  "version": "0.1.0",
  "description": "Capture selected GPT content, organize it, and save it to Notion.",
  "action": {
    "default_title": "Save to Notion",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ]
}
