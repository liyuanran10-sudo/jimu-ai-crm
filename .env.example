PORT=8787
SYNC_TARGET=auto
CRM_AUTH_SECRET=请换成一段随机长字符串
CRM_SESSION_TTL_HOURS=168

# Optional. If missing, the app uses local rule-based AI output so the MVP can still run.
# This can be an OpenAI official key or an OpenAI-compatible proxy key.
OPENAI_API_KEY=
# Configure provider/base URL/model in CRM -> 系统设置 -> 模型.
OPENAI_MODEL=gpt-5.5
# Optional. Useful in any network that needs a local HTTP proxy for the remote model endpoint.
OPENAI_PROXY_URL=
# Remote model request timeout in milliseconds.
OPENAI_TIMEOUT_MS=120000

# Token/cost control from code level: compact customer context before sending to the model.
AI_CONTEXT_MAX_CHARS=16000
AI_PROMPT_MAX_CHARS=22000
AI_OUTPUT_MAX_TOKENS=2800

# Optional image2 generation for customer interaction mockups.
# If missing, CRM returns a clear failure reason and keeps the prompt for retry.
IMAGE2_API_KEY=
IMAGE2_BASE_URL=https://api.openai.com/v1
IMAGE2_ENDPOINT=/images/generations
IMAGE2_EDIT_ENDPOINT=/images/edits
IMAGE2_MODEL=gpt-image-2
IMAGE2_RESPONSES_MODEL=gpt-5.5
IMAGE2_EDIT_MODE=auto
IMAGE2_SIZE=1792x1024
# Leave empty for provider defaults. Some OpenAI-compatible image APIs accept b64_json or url.
IMAGE2_RESPONSE_FORMAT=
IMAGE2_TIMEOUT_MS=180000
IMAGE2_EDIT_TIMEOUT_MS=90000
# Max time to wait for GPT to produce the image prompt before using local customer-context fallback.
IMAGE2_PROMPT_TIMEOUT_MS=25000

# Optional web research tools for AI CRM Skills.
# Default is enabled. The AI service decides whether to search/crawl before generation.
WEB_RESEARCH_ENABLED=true
# Built-in providers: jina (no key, best-effort), tavily (requires WEB_SEARCH_API_KEY/TAVILY_API_KEY).
WEB_SEARCH_PROVIDER=jina
WEB_SEARCH_API_KEY=
# Built-in crawler providers: direct, jina.
WEB_CRAWLER_PROVIDER=direct
WEB_RESEARCH_TIMEOUT_MS=9000
WEB_RESEARCH_MAX_RESULTS=4
WEB_RESEARCH_MAX_CRAWL_URLS=3

# Optional. Configure either NOTION_DATABASE_ID or NOTION_PARENT_PAGE_ID.
# Create an internal Notion integration, copy its secret here, and share the target page/database with the integration.
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_PARENT_PAGE_ID=
NOTION_VERSION=2022-06-28

# Optional Feishu/Lark sync. Set SYNC_TARGET=feishu to force Feishu.
# Use FEISHU_WIKI_SPACE_ID for Feishu Wiki, or FEISHU_FOLDER_TOKEN for normal Feishu Docs.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_FOLDER_TOKEN=
FEISHU_WIKI_SPACE_ID=
FEISHU_WIKI_PARENT_NODE_TOKEN=
FEISHU_SITE_URL=
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
FEISHU_CHAT_ID=
